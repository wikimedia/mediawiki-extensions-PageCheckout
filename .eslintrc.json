{
	"root": true,
	"extends": [
		"wikimedia/client",
		"wikimedia/jquery",
		"wikimedia/mediawiki"
	],
	"parserOptions": {
		"sourceType": "commonjs",
		"ecmaVersion": "latest"
	},
	"globals": {
		"ext": "readonly",
		"ve": "readonly",
		"workflows": "readonly",
		"pagecheckout": "readonly"
	},
	"rules": {
		"max-len": "off",
		"no-jquery/no-done-fail": "warn",
		"es-x/no-async-functions": "off"
	}
}
