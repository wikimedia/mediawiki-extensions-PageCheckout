{
	"root": true,
	"extends": [
		"wikimedia/client-es6",
		"wikimedia/jquery",
		"wikimedia/mediawiki"
	],
	"parserOptions": {
		"sourceType": "commonjs",
		"ecmaVersion": "latest"
	},
	"globals": {
		"ext": "readonly",
		"ve": "readonly",
		"workflows": "readonly",
		"pagecheckout": "readonly"
	},
	"rules": {
		"max-len": "off",
		"es-x/no-async-functions": "off"
	}
}
