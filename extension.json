{
	"name": "PageCheckout",
	"version": "3.1.0-alpha",
	"license-name": "GPL-3.0-only",
	"author": [
		"[https://www.hallowelt.com Hallo Welt! GmbH]"
	],
	"url": "https://en.wiki.bluespice.com/wiki/Reference:PageCheckout",
	"descriptionmsg": "pagecheckout-desc",
	"requires": {
		"MediaWiki": ">= 1.43.0"
	},
	"attributes": {
		"BlueSpiceFoundation": {
			"PermissionRegistry": {
				"page-checkout-clear": {
					"type": "global",
					"roles": [ "admin" ]
				}
			}
		},
		"VisualEditor": {
			"PluginModules": [ "ext.pagecheckout.ve.checkout" ]
		},
		"Workflows": {
			"LogicObjects": {
				"ActivityRegistry": {
					"page_checkout": {
						"class": "MediaWiki\\Extension\\PageCheckout\\Activity\\PageCheckoutActivity",
						"services": [
							"PageCheckoutManager", "UserFactory", "TitleFactory"
						]
					},
					"page_checkin": {
						"class": "MediaWiki\\Extension\\PageCheckout\\Activity\\PageCheckInActivity",
						"services": [
							"PageCheckoutManager", "UserFactory", "TitleFactory"
						]
					}
				}
			},
			"WorkflowListeners": {
				"clear-checkout-on-abort": {
					"class": "MediaWiki\\Extension\\PageCheckout\\Workflows\\Consumer\\ClearCheckoutOnAbort",
					"services": [
						"PageCheckoutManager"
					]
				}
			},
			"EditorPluginModules": [
				"ext.pagecheckout.workflows.editor.customElements"
			]
		},
		"PageCheckout": {
			"Plugins": {}
		}
	},
	"MessagesDirs": {
		"PageCheckout": "i18n"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\PageCheckout\\": "src/"
	},
	"TestAutoloadNamespaces": {
		"MediaWiki\\Extension\\PageCheckout\\Tests\\": "tests/phpunit/"
	},
	"APIModules": {
		"pagecheckout-clear": {
			"class": "MediaWiki\\Extension\\PageCheckout\\Api\\ApiClearCheckout",
			"services": [
				"PageCheckoutManager"
			]
		}
	},
	"ResourceModules": {
		"ext.pagecheckout.workflows.editor.customElements": {
			"scripts": [
				"ui/workflows/inspector/PageCheckinInspector.js",
				"ui/workflows/inspector/PageCheckoutInspector.js",
				"ui/workflows/registerCustomElements.js"
			],
			"styles": [
				"ui/workflows/customElements.css"
			],
			"messages": [
				"pagecheckout-ui-workflows-inspector-activity-page-checkout-title",
				"pagecheckout-ui-workflows-inspector-activity-page-checkout-property-user",
				"pagecheckout-ui-workflows-inspector-activity-page-checkout-property-user-help",
				"pagecheckout-ui-workflows-inspector-activity-page-checkout-property-pagename",
				"pagecheckout-ui-workflows-inspector-activity-page-checkout-property-pagename-help",
				"pagecheckout-ui-workflows-inspector-activity-page-checkout-property-force",
				"pagecheckout-ui-workflows-inspector-activity-page-checkout-property-force-help",
				"pagecheckout-ui-workflows-inspector-activity-page-checkin-title",
				"pagecheckout-ui-workflows-inspector-activity-page-checkin-property-user",
				"pagecheckout-ui-workflows-inspector-activity-page-checkin-property-user-help",
				"pagecheckout-ui-workflows-inspector-activity-page-checkin-property-pagename",
				"pagecheckout-ui-workflows-inspector-activity-page-checkin-property-pagename-help"
			],
			"dependencies": [
				"ext.workflows.editor.inspector.bootstrap",
				"ext.workflows.editor.customElements.bootstrap"
			]
		},
		"ext.pagecheckout.contentActions": {
			"scripts": [
				"contentActions.js"
			],
			"messages": [
				"pagecheckout-ui-clear-confirm",
				"pagecheckout-ui-checkout-confirm"
			],
			"dependencies": [
				"oojs-ui",
				"ext.pagecheckout.boostrap"
			]
		},
		"ext.pagecheckout.checkinDialog": {
			"packageFiles": [
				"ui/CheckinDialog.js"
			],
			"messages": [
				"pagecheckout-ui-cancel-button",
				"pagecheckout-ui-checkin-confirm",
				"pagecheckout-action-checkin-label",
				"pagecheckout-ui-checkin-comment-label"
			],
			"dependencies": [
				"oojs-ui",
				"ext.pagecheckout.boostrap",
				"ext.forms.standalone"
			]
		},
		"ext.pagecheckout.boostrap": {
			"scripts": [
				"bootstrap.js"
			]
		},
		"ext.pagecheckout.ve.checkout": {
			"packageFiles": [
				"ve.checkout.js",
				{
					"name": "config.json",
					"callback": "MediaWiki\\Extension\\PageCheckout\\ClientConfig::getVEPluginConfig"
				}
			],
			"messages": [
				"pagecheckout-ui-checkout-prompt-ve",
				"pagecheckout-ui-cancel-button",
				"pagecheckout-action-checkout-label",
				"pagecheckout-error-save-failed"
			],
			"dependencies": [
				"ext.pagecheckout.boostrap"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "PageCheckout/resources"
	},
	"Hooks": {
		"LoadExtensionSchemaUpdates": "addDatabaseTables",
		"getUserPermissionsErrors": "applyCheckout",
		"SkinTemplateNavigation::Universal": "addContentActions",
		"BlueSpiceDiscoveryTemplateDataProviderAfterInit": "discovery-skin",
		"MWStakeAlertBannersRegisterProviders": "addAlertBanner",
		"GetPreferences": "addPreferences"
	},
	"HookHandlers": {
		"addDatabaseTables": {
			"class": "MediaWiki\\Extension\\PageCheckout\\Hook\\AddDatabaseTables"
		},
		"applyCheckout": {
			"class": "MediaWiki\\Extension\\PageCheckout\\Hook\\ApplyCheckout",
			"services": [
				"PageCheckoutManager"
			]
		},
		"addContentActions": {
			"class": "MediaWiki\\Extension\\PageCheckout\\Hook\\AddContentActions",
			"services": [
				"PermissionManager",
				"PageCheckoutManager"
			]
		},
		"addAlertBanner": {
			"class": "\\MediaWiki\\Extension\\PageCheckout\\Hook\\AddAlertBanner"
		},
		"discovery-skin": {
			"class": "\\MediaWiki\\Extension\\PageCheckout\\HookHandler\\DiscoverySkin"
		},
		"addPreferences": {
			"class": "\\MediaWiki\\Extension\\PageCheckout\\Hook\\AddUserPreferences",
			"services": [
				"UserOptionsLookup",
				"MainConfig"
			]
		}
	},
	"GroupPermissions": {
		"user": {
			"page-checkout-clear": false
		},
		"sysop": {
			"page-checkout-clear": true
		}
	},
	"AvailableRights": [
		"page-checkout-clear"
	],
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"LogTypes": [ "pagecheckout" ],
	"LogActionsHandlers": {
		"pagecheckout/*": "LogFormatter"
	},
	"config": {
		"PageCheckoutPromptToCheckoutOnEdit": {
			"value": true,
			"description": "If true, users will be prompted to checkout a page when they attempt to edit it without having it checked out."
		}
	},
	"RestRoutes": [
		{
			"path": "/pagecheckout/clear",
			"method": "POST",
			"class": "MediaWiki\\Extension\\PageCheckout\\Rest\\ClearCheckoutHandler",
			"services": [ "PageCheckoutManager", "PermissionManager", "TitleFactory" ]
		},
		{
			"path": "/pagecheckout/checkout",
			"method": "POST",
			"class": "MediaWiki\\Extension\\PageCheckout\\Rest\\CheckoutHandler",
			"services": [ "PageCheckoutManager", "PermissionManager", "TitleFactory" ]
		},
		{
			"path": "/pagecheckout/checkin",
			"method": "POST",
			"class": "MediaWiki\\Extension\\PageCheckout\\Rest\\CheckinHandler",
			"services": [ "PageCheckoutManager", "TitleFactory" ]
		},
		{
			"path": "/pagecheckout/plugins/{pageId}",
			"method": "GET",
			"class": "MediaWiki\\Extension\\PageCheckout\\Rest\\PluginHandler",
			"services": [ "PageCheckout.PluginManager", "TitleFactory" ]
		},
		{
			"path": "/pagecheckout/has_checkout/{pageId}",
			"method": "GET",
			"class": "MediaWiki\\Extension\\PageCheckout\\Rest\\HasCheckoutHandler",
			"services": [ "PageCheckoutManager", "TitleFactory" ]
		}
	],
	"manifest_version": 2
}
